<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="TextAppearance.Walkin.Base" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">@font/font_primary_regular</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.Walkin.Caption.C1.Medium" parent="TextAppearance.Walkin.Base">
        <item name="android:fontFamily">@font/font_primary_medium</item>
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="android:lineHeight" tools:targetApi="28">@dimen/_16ssp</item>
    </style>

    <style name="TextAppearance.Walkin.Body.B1.SemiBold" parent="TextAppearance.Walkin.Base">
        <item name="android:fontFamily">@font/font_primary_semibold</item>
        <item name="android:textSize">@dimen/_16ssp</item>
        <item name="android:lineHeight" tools:targetApi="28">@dimen/_22ssp</item>
    </style>

    <style name="TextAppearance.Walkin.Heading.H2.Bold" parent="TextAppearance.Walkin.Base">
        <item name="android:fontFamily">@font/font_primary_bold</item>
        <item name="android:textSize">@dimen/_24ssp</item>
        <item name="android:lineHeight" tools:targetApi="28">@dimen/_32ssp</item>
    </style>


    <style name="Widget.Walkin.Card.Category" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">@dimen/_12sdp</item>
        <item name="contentPaddingLeft">@dimen/_12sdp</item>
        <item name="contentPaddingTop">@dimen/_12sdp</item>
        <item name="contentPaddingRight">@dimen/_12sdp</item>
        <item name="contentPaddingBottom">@dimen/_12sdp</item>
    </style>


    <style name="Widget.Walkin.Card.InfoBanner" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">@dimen/_12sdp</item>
        <item name="contentPaddingLeft">@dimen/_16sdp</item>
        <item name="contentPaddingTop">@dimen/_12sdp</item>
        <item name="contentPaddingRight">@dimen/_16sdp</item>
        <item name="contentPaddingBottom">@dimen/_12sdp</item>
    </style>

</resources>
